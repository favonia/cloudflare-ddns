{
  "shared": {
    "exclude": [
      "docs/private/**"
    ]
  },
  "local_markdown": {
    "include": [
      "*.md",
      "*.markdown",
      "**/*.md",
      "**/*.markdown"
    ]
  },
  "repo_paths": {
    "include": [
      "*.go",
      "*.yaml",
      "*.yml",
      "**/*.go",
      "**/*.yaml",
      "**/*.yml"
    ],
    "ignore": []
  },
  "external": {
    "include": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml",
      "*.go",
      "*.json",
      "*.yaml",
      "*.yml",
      "*.md",
      "*.markdown",
      "**/*.go",
      "**/*.json",
      "**/*.yaml",
      "**/*.yml",
      "**/*.md",
      "**/*.markdown"
    ],
    "exclude": [
      "**/*_test.go"
    ],
    "ignore_urls": [
      "https://api.github.com"
    ],
    "ignore_url_patterns": [
      "^https?:///",
      "^https?://(?:0\\.0\\.0\\.0|1\\.2\\.3\\.4)(?:[/:?]|$)",
      "^https?://[^/\\s]*example(?:\\.com)?(?:[/:?]|$)",
      "^https://(?:healthchecks|uptime)\\.example(?:[/:?]|$)",
      "^https://hc-ping\\.com/01234567-0123-0123-0123-0123456789abc$",
      "^https://localhost(?:[/:?]|$)",
      "^https://some\\.host\\.name(?:[/:?]|$)",
      "^https://user:pass@host(?:[/:?]|$)",
      "%s"
    ]
  },
  "external_probe": {
    "timeout_seconds": 10,
    "retries": 1,
    "max_workers": 8,
    "user_agent": "cloudflare-ddns-link-check/1.0",
    "network_errors_are_warnings": false,
    "warning_statuses": [
      403,
      429
    ],
    "warning_url_patterns": [
      "^https://api.cloudflare.com/client/v4/user/tokens/verify$",
      "^https://api4\\.ipify\\.org/?$",
      "^https://api6\\.ipify\\.org/?$",
      "^https://cloudflare-dns\\.com/dns-query$",
      "^https://(?:api\\.cloudflare\\.com|one\\.one\\.one\\.one)/cdn-cgi/trace$",
      "^https://dash\\.cloudflare\\.com/\\?to=",
      "^https://token\\.actions\\.githubusercontent\\.com/?$"
    ]
  }
}
