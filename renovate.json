{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":semanticCommitTypeAll(build)",
    "customManagers:githubActionsVersions"
  ],
  "pip-compile": {
    "managerFilePatterns": [
      "/(^|/)\\.github/workflows/mdformat-requirements\\.txt$/"
    ],
    "lockFileMaintenance": {
      "enabled": false
    }
  },
  "pip_requirements": {
    "enabled": false
  },
  "schedule": [
    "on the first day instance on friday after 9pm"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "github.com/cloudflare/cloudflare-go"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker/dockerfile"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "pip-compile"
      ],
      "matchPackageNames": [
        "mdformat",
        "mdformat-gfm"
      ],
      "groupName": "mdformat"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
