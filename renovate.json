{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    ":semanticCommitTypeAll(build)",
    "customManagers:githubActionsVersions"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)lean-toolchain$/"
      ],
      "matchStrings": [
        "leanprover/lean4:(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "leanprover/lean4",
      "datasourceTemplate": "github-releases"
    }
  ],
  "pip-compile": {
    "managerFilePatterns": [
      "/(^|/)\\.github/workflows/mdformat-requirements\\.txt$/"
    ],
    "lockFileMaintenance": {
      "enabled": false
    }
  },
  "pip_requirements": {
    "enabled": false
  },
  "schedule": [
    "on the first day instance on friday after 9pm"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "github.com/cloudflare/cloudflare-go"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker/dockerfile"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "pip-compile"
      ],
      "matchPackageNames": [
        "mdformat",
        "mdformat-gfm"
      ],
      "groupName": "mdformat"
    },
    {
      "matchPackageNames": [
        "leanprover/lean4"
      ],
      "groupName": "Lean toolchain"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
